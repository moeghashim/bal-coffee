SITE_NAME="Bal Coffee"

# --- Legacy hand-rolled Storefront layer (still in use until the commerce
# adapter migration completes; see HYDROGEN_MIGRATION.md) ---
SHOPIFY_STORE_DOMAIN="bal-coffee.myshopify.com"
SHOPIFY_STOREFRONT_ACCESS_TOKEN=""
SHOPIFY_STOREFRONT_API_VERSION="2025-10"
SHOPIFY_WEBHOOK_SECRET=""

# --- Hydrogen toolkit (@shopify/hydrogen) expected env vars ---
# Map from the legacy pair above: PUBLIC_STORE_DOMAIN = SHOPIFY_STORE_DOMAIN,
# PRIVATE_STOREFRONT_API_TOKEN = SHOPIFY_STOREFRONT_ACCESS_TOKEN.
# Must also be set in Vercel project settings before the adapter goes live.
PUBLIC_STORE_DOMAIN="bal-coffee.myshopify.com"
PRIVATE_STOREFRONT_API_TOKEN=""

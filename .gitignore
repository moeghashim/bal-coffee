# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/package-lock.json
/.pnp
.pnp.js

# testing
/coverage
.playwright

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*
!.env.example

# vercel
.vercel

# claude code — keep local agent config ignored, but VERSION-CONTROL the
# version-matched Hydrogen toolkit skills so they travel with the pinned package
# (see HYDROGEN_MIGRATION.md). New hydrogen-* skills auto-track on upgrade.
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/hydrogen-*

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# Playwright
/test-results/
/playwright-report/
/blob-report/
/.playwright/

# gql.tada editor-generated schema types
graphql-env.d.ts
*-graphql-env.d.ts
